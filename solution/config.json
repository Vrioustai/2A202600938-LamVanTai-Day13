{
  "provider": "openai",
  "model": "deepseek-chat",
  "model_price_tier": "standard",
  "max_steps": 12,
  "loop_guard": true,
  "temperature": 0.2,
  "context_size": 2,
  "verbose_system": false,
  "timeout_ms": 60000,
  "max_completion_tokens": 120,
  "retry": {"enabled": true, "max_attempts": 3, "backoff_ms": 500},
  "cache": {"enabled": true},
  "normalize_unicode": true,
  "redact_pii": true,
  "session_drift_rate": 0.0,
  "context_reset_every": 8,
  "tool_error_rate": 0.18,
  "catalog_override": {},
  "route_rules": [],
  "planner": false,
  "verify": true,
  "self_consistency": 1,
  "tool_budget": 3
}
